# ================================
# Application Configuration
# ================================
APP_NAME=CriticalCyberSim
PLATFORM_NAME=CriticalCyberSim

# Environment: local, production, staging
# PRODUCTION: Set to 'production'
APP_ENV=local

# SECURITY: Generate with 'php artisan key:generate'
# PRODUCTION: Never share this key!
APP_KEY=

# PRODUCTION: Set to 'false' in production to hide errors
APP_DEBUG=true

APP_TIMEZONE=UTC

# PRODUCTION: Set to your actual domain (with https://)
APP_URL=http://localhost

# ================================
# Localization
# ================================
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ================================
# Maintenance Mode
# ================================
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# ================================
# Performance
# ================================
PHP_CLI_SERVER_WORKERS=4

# SECURITY: Higher = more secure but slower (12 recommended)
BCRYPT_ROUNDS=12

# ================================
# Logging
# ================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null

# PRODUCTION: Set to 'error' or 'warning' in production
LOG_LEVEL=debug

# ================================
# Database Configuration
# ================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=criticalcybersim
DB_USERNAME=root

# SECURITY: Set a strong password in production!
# PRODUCTION: Use a non-root user with limited privileges
DB_PASSWORD=

# ================================
# Session Configuration
# ================================
SESSION_DRIVER=database
SESSION_LIFETIME=120

# PRODUCTION: Set to 'true' for encrypted sessions
SESSION_ENCRYPT=false

SESSION_PATH=/
SESSION_DOMAIN=null

# PRODUCTION: Recommended session security settings
# SESSION_SECURE_COOKIE=true
# SESSION_HTTP_ONLY=true
# SESSION_SAME_SITE=strict

# ================================
# Broadcasting & Queues
# ================================
BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database

# ================================
# Filesystem & Cache
# ================================
FILESYSTEM_DISK=local

# PRODUCTION: Use redis for better performance
CACHE_STORE=database
CACHE_PREFIX=

# ================================
# Cache Services
# ================================
MEMCACHED_HOST=127.0.0.1

# ================================
# Redis Configuration
# ================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# SECURITY: Set a strong password in production!
REDIS_PASSWORD=null

# ================================
# Mail Configuration
# ================================
# Options: smtp, ses, mailgun, postmark, sendmail, log
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null

# SECURITY: Never commit real mail passwords!
MAIL_PASSWORD=null

MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ================================
# AWS Configuration
# ================================
# SECURITY: Never commit real AWS credentials!
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ================================
# Frontend Build (Vite)
# ================================
VITE_APP_NAME="${APP_NAME}"

# ================================
# Additional Security Settings
# ================================
# Uncomment these in production:
# SANCTUM_STATEFUL_DOMAINS=yourdomain.com
# ASSET_URL=https://yourdomain.com
